#!/usr/bin/env node

const fs = require('fs');
const http = require('http');
const path = require('path');
const dotenv = require('dotenv');

const appRoot = path.resolve(__dirname, '..');
const repoRoot = path.resolve(appRoot, '..', '..');
const environment = process.env.NODE_ENV || 'development';
const envFiles = [
  '.env',
  '.env.local',
  '.env.' + environment,
  '.env.' + environment + '.local'
];

const loadEnvFrom = (baseDir) => {
  envFiles.forEach((envFile) => {
    const envPath = path.join(baseDir, envFile);
    if (fs.existsSync(envPath)) {
      dotenv.config({ path: envPath, override: true });
    }
  });
};

// Load repo-level env first, then app-level env so app-local values can override.
loadEnvFrom(repoRoot);
loadEnvFrom(appRoot);

const app = require('../app');

const normalizePort = (val) => {
  const parsedPort = parseInt(val, 10);

  if (isNaN(parsedPort)) return val;
  if (parsedPort >= 0) return parsedPort;
  return false;
};

const port = normalizePort(process.env.PORT || process.env.API_PORT || '3000');

app.set('port', port);

const server = http.createServer(app);
server.listen(port);
server.on('listening', () => {
  const addr = server.address();
  if (addr && typeof addr === 'object') {
    console.log('API listening at http://localhost:' + addr.port + ' (tasks: /tasks)');
    return;
  }
  console.log('API listening on ' + String(addr));
});
